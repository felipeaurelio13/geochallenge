# GeoChallenge — variables para el deploy con docker-compose.
# Copia este archivo a .env y rellena los valores reales.
# El .env NO se sube a git (está en .gitignore).
#
#   cp .env.example .env

# Dominio público del juego, SIN https://.
# Caddy saca el certificado HTTPS automáticamente para este dominio.
# Gratis: crea un subdominio en https://www.duckdns.org y apúntalo a la IP de tu VM.
DOMAIN=geochallenge.duckdns.org

# Contraseña de la base de datos Postgres. Inventa una larga.
#   genera una con:  openssl rand -hex 24
POSTGRES_PASSWORD=cambiame-por-algo-largo

# Secreto para firmar los tokens JWT. OBLIGATORIO cambiarlo.
#   genera uno con:  openssl rand -hex 32
JWT_SECRET=cambiame-por-algo-aleatorio-y-largo
