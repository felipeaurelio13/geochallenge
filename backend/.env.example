# Database
DATABASE_URL="postgresql://user:password@localhost:5432/geochallenge?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="24h"

# Server
PORT=3001
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL="http://localhost:5173"

# Test auth bypass (solo para tests/local)
ENABLE_TEST_AUTH_BYPASS=false
TEST_AUTH_BYPASS_SECRET=""
TEST_AUTH_BYPASS_EMAIL="test-runner@geochallenge.local"

# Token para endpoints administrativos (rebuild de leaderboards, etc).
# Si queda vacío, los endpoints admin responden 404.
ADMIN_TOKEN=""

# Email transaccional (recuperación de contraseña) via Resend (https://resend.com).
# Ambas son OPCIONALES: sin RESEND_API_KEY, el flujo de forgot-password sigue
# respondiendo 200 pero no envía el email (solo loggea un warning). Útil para
# desarrollo local sin cuenta de Resend.
RESEND_API_KEY=""
EMAIL_FROM="GeoChallenge <no-reply@geochallenge.app>"

### Feature toggles de juego (defaults entre paréntesis; ver src/config/env.ts)

# Seed: incluir banderas extendidas (false)
ENABLE_EXTENDED_FLAGS=false

# Scoring progresivo por combo en modo flash (false)
ENABLE_COMBO_SCORING=false
# Puntos extra por nivel de combo (10) y tope del bonus (50)
COMBO_STEP=10
COMBO_CAP=50
# Segundos restantes mínimos para que una respuesta cuente como "rápida" (3)
FAST_ANSWER_THRESHOLD=3

# Estrategia de scoring en modos solo: simple_1_0 | progressive_combo (simple_1_0)
SOLO_MODE_SCORING_STRATEGY=simple_1_0

# Modo streak: scoring simple (true) y preguntas sin repetir (true)
ENABLE_STREAK_SIMPLE_SCORING=true
ENABLE_STREAK_UNIQUE_QUESTIONS=true

# Mecánicas (power-ups) por modo: single/flash activas por default,
# duel/challenge desactivadas por default
ENABLE_MECHANICS_SINGLE=true
ENABLE_MECHANICS_FLASH=true
ENABLE_MECHANICS_DUEL=false
ENABLE_MECHANICS_CHALLENGE=false

# Usos por partida de cada mecánica (1)
MECHANIC_LIMIT_INTEL5050=1
MECHANIC_LIMIT_FOCUS_TIME=1
MECHANIC_LIMIT_STREAK_SHIELD=1
# Segundos que agrega Focus Time (3)
MECHANIC_FOCUS_TIME_BONUS_SECONDS=3
