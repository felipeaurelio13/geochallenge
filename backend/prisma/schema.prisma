generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String      @id @default(cuid())
  username          String      @unique
  email             String      @unique
  passwordHash      String
  preferredLanguage String      @default("es")
  highScore         Int         @default(0)
  gamesPlayed       Int         @default(0)
  wins              Int         @default(0)
  losses            Int         @default(0)
  dailyStreak       Int         @default(0)
  lastDailyDate     String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  // Relaciones
  games              GameResult[]
  challengesCreated  Challenge[]            @relation("ChallengeCreator")
  challengeParticipations ChallengeParticipant[]
  duelMatchesAsP1    DuelMatch[] @relation("DuelMatchAsP1")
  duelMatchesAsP2    DuelMatch[] @relation("DuelMatchAsP2")
  duelMatchesWon     DuelMatch[] @relation("DuelMatchAsWinner")
  achievements       UserAchievement[]
  survivalParticipations SurvivalParticipant[]

  @@map("users")
}

model Question {
  id             String   @id @default(cuid())
  category       Category
  questionData   String   // Nombre del país/ciudad o prompt
  options        String[] // Opciones para múltiple choice
  correctAnswer  String
  imageUrl       String?  // URL de bandera o silueta
  latitude       Float?   // Para preguntas de mapa
  longitude      Float?   // Para preguntas de mapa
  continent      String?  // Para generar distractores regionales
  difficulty     Difficulty @default(MEDIUM)
  isAvailable    Boolean  @default(true) // false = imagen no accesible en ningún CDN
  isInsular      Boolean?
  isLandlocked   Boolean?
  subregion      String?
  populationTier String?
  areaTier       String?
  flagComplexity String?
  createdAt      DateTime @default(now())

  @@index([category])
  @@index([isAvailable])
  @@map("questions")
}

model GameResult {
  id            String   @id @default(cuid())
  userId        String
  score         Int
  correctCount  Int
  totalQuestions Int
  category      Category?
  gameMode      GameMode @default(SINGLE)
  details       Json?    // Desglose de respuestas
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("game_results")
}

model Challenge {
  id              String          @id @default(cuid())
  creatorId       String
  status          ChallengeStatus @default(PENDING)
  categories      Category[]
  maxPlayers      Int
  answerTimeSeconds Int          @default(20)
  questionIds     String[]        // IDs de preguntas para reproducibilidad
  filters         Json?           // QuestionFilters snapshot — null means no filters applied
  winnerId        String?
  createdAt       DateTime        @default(now())
  expiresAt       DateTime
  completedAt     DateTime?

  creator User @relation("ChallengeCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  participants ChallengeParticipant[]

  @@index([status, expiresAt])
  @@index([creatorId])
  @@map("challenges")
}

model ChallengeParticipant {
  id          String   @id @default(cuid())
  challengeId String
  userId      String
  score       Int?
  correctCount Int?
  joinedAt    DateTime @default(now())
  completedAt DateTime?

  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([challengeId, userId])
  @@map("challenge_participants")
}

enum Category {
  MAP
  FLAG
  CAPITAL
  SILHOUETTE
  MONUMENT
  MIXED
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum GameMode {
  SINGLE
  DUEL
  CHALLENGE
  SURVIVAL
}

model DuelMatch {
  id           String    @id @default(cuid())
  player1Id    String
  player2Id    String
  winnerId     String?
  player1Score Int
  player2Score Int
  category     Category?
  createdAt    DateTime  @default(now())

  player1 User  @relation("DuelMatchAsP1", fields: [player1Id], references: [id], onDelete: Cascade)
  player2 User  @relation("DuelMatchAsP2", fields: [player2Id], references: [id], onDelete: Cascade)
  winner  User? @relation("DuelMatchAsWinner", fields: [winnerId], references: [id], onDelete: SetNull)

  @@index([player1Id, createdAt])
  @@index([player2Id, createdAt])
  @@map("duel_matches")
}

model SurvivalMatch {
  id           String   @id @default(cuid())
  category     Category?
  totalRounds  Int
  peakPlayers  Int
  createdAt    DateTime @default(now())

  participants SurvivalParticipant[]

  @@index([createdAt])
  @@map("survival_matches")
}

model SurvivalParticipant {
  id             String        @id @default(cuid())
  matchId        String
  userId         String
  finalRank      Int
  eliminatedRound Int?
  finalScore     Int
  correctCount   Int
  livesEarned    Int           @default(0)

  match SurvivalMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([matchId])
  @@map("survival_participants")
}

enum ChallengeStatus {
  PENDING
  ACCEPTED
  COMPLETED
  EXPIRED
  DECLINED
}

model Achievement {
  id          String   @id @default(cuid())
  key         String   @unique
  nameEs      String
  nameEn      String
  descEs      String
  descEn      String
  icon        String

  earnedBy    UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  achievementId String
  earnedAt      DateTime    @default(now())
  meta          Json?

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@map("user_achievements")
}
